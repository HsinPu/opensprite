{
  "llm": {
    "providers_file": "llm.providers.json",
    "default": null,
    "context_window_tokens": null
  },
  "storage": {
    "type": "sqlite",
    "path": "~/.opensprite/data/sessions.db"
  },
  "channels_file": "channels.json",
  "search_file": "search.json",
  "media_file": "media.json",
  "messages_file": "messages.json",
  "log": {
    "enabled": true,
    "retention_days": 365,
    "level": "INFO",
    "log_system_prompt": true,
    "log_system_prompt_lines": 0,
    "log_reasoning_details": false
  },
  "network": {
    "http_proxy": "",
    "https_proxy": "",
    "no_proxy": "127.0.0.1,localhost"
  },
  "tools": {
    "max_tool_iterations": 200,
    "exec": {
      "timeout": 60
    },
    "web_search": {
      "provider": "duckduckgo",
        "freshness": "auto",
      "jina_api_key": "",
      "searxng_url": "https://searx.be",
      "searxng_engines": [],
      "searxng_categories": [],
      "max_results": 25,
      "duckduckgo_max_pages": 10,
      "searxng_max_pages": 5,
      "proxy": null
    },
    "web_fetch": {
      "max_chars": 50000,
      "max_response_size": 5242880,
      "timeout": 30,
      "prefer_trafilatura": true,
      "firecrawl_api_key": ""
    },
    "browser": {
      "enabled": false,
      "backend": "agent-browser",
      "command_timeout": 30,
      "session_timeout": 1800,
      "cdp_url": "",
      "launch_args": "--no-sandbox",
      "allow_private_urls": false,
      "browserbase_api_key": "",
      "browserbase_project_id": "",
      "browserbase_base_url": "https://api.browserbase.com",
      "browserbase_proxies": true,
      "browserbase_advanced_stealth": false,
      "browserbase_keep_alive": true,
      "browser_use_api_key": "",
      "browser_use_base_url": "https://api.browser-use.com/api/v3",
      "firecrawl_api_key": "",
      "firecrawl_base_url": "https://api.firecrawl.dev"
    },
    "cron": {
      "default_timezone": "UTC"
    },
    "mcp_servers_file": "mcp_servers.json"
  },
  "agent": {
    "max_history": 300,
    "history_token_budget": 200000,
    "llm_request_timeout_seconds": 120,
    "context_output_reserve_tokens": 32768,
    "context_compaction_enabled": true,
    "context_compaction_threshold_ratio": 0.9,
    "context_compaction_min_messages": 8,
    "context_compaction_strategy": "deterministic",
    "context_compaction_llm": {
      "max_tokens": 4096
    },
    "context_overflow_error_markers": [
      "context length",
      "context_length_exceeded",
      "context window",
      "maximum context",
      "maximum context length",
      "maximum token",
      "too many tokens",
      "token limit",
      "tokens exceed",
      "input is too long",
      "prompt is too long",
      "reduce the length"
    ],
    "auto_continue_default_budget": 1,
    "auto_continue_long_running_budget": 3,
    "auto_continue_deterministic_action_budget": 4,
    "subagent_max_tool_iterations": 100,
    "task_context_llm": {
      "max_tokens": 500
    },
    "task_objective_llm": {
      "max_tokens": 500
    },
    "task_planner_llm": {
      "max_tokens": 400
    },
    "completion_judge_llm": {
      "max_tokens": 700
    },
    "skill_review_enabled": true,
    "skill_review_min_tool_calls": 5,
    "skill_review_max_tool_iterations": 6,
    "skill_review_transcript_messages": 50,
    "worktree_sandbox_enabled": false
  },
  "memory": {
    "threshold": 80,
    "token_threshold": 240000,
    "llm": {
      "max_tokens": 2048
    }
  },
  "user_profile": {
    "enabled": true,
    "threshold": 40,
    "lookback_messages": 80,
    "llm": {
      "max_tokens": 1200
    }
  },
  "active_task": {
    "enabled": true,
    "threshold": 2,
    "lookback_messages": 40,
    "llm": {
      "max_tokens": 1200
    }
  },
  "recent_summary": {
    "enabled": true,
    "threshold": 40,
    "token_threshold": 120000,
    "lookback_messages": 240,
    "keep_last_messages": 80,
    "llm": {
      "max_tokens": 1200
    }
  }
}
